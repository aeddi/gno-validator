# Password to decrypt the gnokms signing key.
# Optional and less safe — if not set, 'make up' and 'make update' will prompt for it at startup.
GNOKMS_PASSWORD=

# Optional — gno source version to build (branch, tag, or commit hash; default: master)
GNO_VERSION=master

# Optional — GitHub repo slug to clone gno sources from (default: gnolang/gno)
GNO_REPO=gnolang/gno

# Optional — host ports mapped to gnoland (default: 26657 RPC, 26656 P2P)
GNOLAND_RPC_PORT=26657
GNOLAND_P2P_PORT=26656

# Optional — host port for Grafana web UI (default: 3000)
GRAFANA_PORT=3000

# Optional — if set (to any non-empty value), passes --x-early-start to gnoland
GNOLAND_EARLY_START=

# Optional — if set (to any non-empty value), syncs the system clock via NTP at startup (default: 1)
GNOLAND_NTP_UPDATE=1

# Optional — number of 1 GB gnoland log files to keep (default: 30)
GNOLAND_LOG_SIZE=
